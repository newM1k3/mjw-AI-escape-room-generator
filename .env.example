# PocketBase instance URL
VITE_POCKETBASE_URL=https://immersive-kit.pockethost.io

# Public base URL of this app (used for CORS and redirect URLs)
VITE_APP_BASE_URL=https://roomgen.immersivekit.ca
APP_BASE_URL=https://roomgen.immersivekit.ca

# Support email shown in UI
VITE_SUPPORT_EMAIL=support@immersivekit.ca

# AI provider: anthropic | openai | gemini | mock
AI_PROVIDER=anthropic
# Optional model override. Defaults per provider: anthropic -> claude-opus-4-8,
# openai -> gpt-4.1-mini, gemini -> gemini-2.5-flash. Use claude-sonnet-4-6 for lower latency.
AI_MODEL=
# Provider key for the selected AI_PROVIDER (only the matching one is required):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Server-side PocketBase config the generate-room function requires (NOT VITE_*):
PB_URL=https://immersive-kit.pockethost.io
PB_SUPERUSER_TOKEN=

# Rate limiting — seconds between generations per user (default: 30)
GENERATION_COOLDOWN_SECONDS=30

# Note: URL, DEPLOY_URL, DEPLOY_PRIME_URL are set automatically by Netlify
